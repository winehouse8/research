{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://example.com/certification/evidence-record.schema.json",
  "title": "CertificationEvidenceRecord",
  "description": "Schema for software certification evidence records generated from JIRA and GitHub CI/CD pipeline data.",
  "type": "object",
  "required": [
    "schema_version",
    "record_id",
    "generated_at",
    "release_tag",
    "jira_ticket",
    "github_pr",
    "reviews",
    "ci_results",
    "commits",
    "approvals",
    "traceability",
    "standard_compliance",
    "integrity"
  ],
  "additionalProperties": false,
  "properties": {
    "schema_version": {
      "type": "string",
      "description": "Semantic version of this schema.",
      "pattern": "^\\d+\\.\\d+\\.\\d+$",
      "examples": ["1.0.0"]
    },
    "record_id": {
      "type": "string",
      "description": "Universally unique identifier for this evidence record.",
      "format": "uuid",
      "pattern": "^[0-9a-fA-F]{8}-[0-9a-fA-F]{4}-[0-9a-fA-F]{4}-[0-9a-fA-F]{4}-[0-9a-fA-F]{12}$"
    },
    "generated_at": {
      "type": "string",
      "description": "ISO-8601 datetime when this record was generated.",
      "format": "date-time"
    },
    "release_tag": {
      "type": "string",
      "description": "Git release tag or version identifier associated with this evidence record.",
      "minLength": 1
    },
    "jira_ticket": {
      "type": "object",
      "description": "JIRA ticket details linked to this change.",
      "required": ["id", "summary", "status", "assignee", "reporter", "created_at"],
      "additionalProperties": false,
      "properties": {
        "id": {
          "type": "string",
          "description": "JIRA ticket ID, e.g. PROJECT-123.",
          "pattern": "^[A-Z]+-\\d+$"
        },
        "summary": {
          "type": "string",
          "description": "JIRA ticket summary/title.",
          "minLength": 1
        },
        "status": {
          "type": "string",
          "description": "Current status of the JIRA ticket.",
          "examples": ["Open", "In Progress", "In Review", "Done", "Closed"]
        },
        "assignee": {
          "type": ["string", "null"],
          "description": "Username or display name of the ticket assignee."
        },
        "reporter": {
          "type": "string",
          "description": "Username or display name of the ticket reporter."
        },
        "created_at": {
          "type": "string",
          "description": "ISO-8601 datetime when the ticket was created.",
          "format": "date-time"
        },
        "resolved_at": {
          "type": ["string", "null"],
          "description": "ISO-8601 datetime when the ticket was resolved, or null if unresolved.",
          "format": "date-time"
        },
        "workflow_history": {
          "type": "array",
          "description": "Ordered list of workflow status transitions for this ticket.",
          "items": {
            "type": "object",
            "required": ["status", "transitioned_at", "transitioned_by"],
            "additionalProperties": false,
            "properties": {
              "status": {
                "type": "string",
                "description": "Status name after this transition.",
                "minLength": 1
              },
              "transitioned_at": {
                "type": "string",
                "description": "ISO-8601 datetime of the transition.",
                "format": "date-time"
              },
              "transitioned_by": {
                "type": "string",
                "description": "Username or display name of the person who performed the transition.",
                "minLength": 1
              }
            }
          }
        }
      }
    },
    "github_pr": {
      "type": "object",
      "description": "GitHub Pull Request details.",
      "required": ["url", "number", "title", "author", "created_at", "base_branch", "head_branch"],
      "additionalProperties": false,
      "properties": {
        "url": {
          "type": "string",
          "description": "HTML URL of the pull request.",
          "format": "uri"
        },
        "number": {
          "type": "integer",
          "description": "Pull request number within the repository.",
          "minimum": 1
        },
        "title": {
          "type": "string",
          "description": "Pull request title.",
          "minLength": 1
        },
        "author": {
          "type": "string",
          "description": "GitHub username of the pull request author.",
          "minLength": 1
        },
        "created_at": {
          "type": "string",
          "description": "ISO-8601 datetime when the PR was created.",
          "format": "date-time"
        },
        "merged_at": {
          "type": ["string", "null"],
          "description": "ISO-8601 datetime when the PR was merged, or null if not merged.",
          "format": "date-time"
        },
        "merge_commit_sha": {
          "type": ["string", "null"],
          "description": "SHA of the merge commit, or null if not merged.",
          "pattern": "^[0-9a-fA-F]{40}$"
        },
        "base_branch": {
          "type": "string",
          "description": "Target branch of the pull request.",
          "minLength": 1
        },
        "head_branch": {
          "type": "string",
          "description": "Source branch of the pull request.",
          "minLength": 1
        }
      }
    },
    "reviews": {
      "type": "array",
      "description": "List of pull request reviews submitted.",
      "items": {
        "type": "object",
        "required": ["reviewer", "submitted_at", "state"],
        "additionalProperties": false,
        "properties": {
          "reviewer": {
            "type": "string",
            "description": "GitHub username of the reviewer.",
            "minLength": 1
          },
          "submitted_at": {
            "type": "string",
            "description": "ISO-8601 datetime when the review was submitted.",
            "format": "date-time"
          },
          "state": {
            "type": "string",
            "description": "Review state.",
            "enum": ["approved", "changes_requested", "commented"]
          },
          "body_excerpt": {
            "type": ["string", "null"],
            "description": "First 500 characters of the review body, or null if no body.",
            "maxLength": 500
          }
        }
      }
    },
    "ci_results": {
      "type": "object",
      "description": "Continuous integration pipeline results.",
      "required": [
        "workflow_run_id",
        "workflow_name",
        "conclusion",
        "started_at",
        "completed_at",
        "test_summary",
        "coverage_percent",
        "sast_findings_count"
      ],
      "additionalProperties": false,
      "properties": {
        "workflow_run_id": {
          "type": "integer",
          "description": "GitHub Actions workflow run ID.",
          "minimum": 1
        },
        "workflow_name": {
          "type": "string",
          "description": "Name of the GitHub Actions workflow.",
          "minLength": 1
        },
        "conclusion": {
          "type": "string",
          "description": "Final conclusion of the workflow run.",
          "enum": ["success", "failure", "cancelled", "skipped", "timed_out", "action_required", "neutral", "stale"]
        },
        "started_at": {
          "type": "string",
          "description": "ISO-8601 datetime when the workflow run started.",
          "format": "date-time"
        },
        "completed_at": {
          "type": "string",
          "description": "ISO-8601 datetime when the workflow run completed.",
          "format": "date-time"
        },
        "test_summary": {
          "type": "object",
          "description": "Aggregated test result counts.",
          "required": ["passed", "failed", "skipped"],
          "additionalProperties": false,
          "properties": {
            "passed": {
              "type": "integer",
              "description": "Number of passing tests.",
              "minimum": 0
            },
            "failed": {
              "type": "integer",
              "description": "Number of failing tests.",
              "minimum": 0
            },
            "skipped": {
              "type": "integer",
              "description": "Number of skipped tests.",
              "minimum": 0
            }
          }
        },
        "coverage_percent": {
          "type": ["number", "null"],
          "description": "Code coverage percentage (0-100), or null if not measured.",
          "minimum": 0,
          "maximum": 100
        },
        "sast_findings_count": {
          "type": ["integer", "null"],
          "description": "Number of SAST (Static Application Security Testing) findings, or null if not run.",
          "minimum": 0
        }
      }
    },
    "commits": {
      "type": "array",
      "description": "List of commits included in this pull request.",
      "items": {
        "type": "object",
        "required": ["sha", "author", "message", "timestamp"],
        "additionalProperties": false,
        "properties": {
          "sha": {
            "type": "string",
            "description": "Full 40-character commit SHA.",
            "pattern": "^[0-9a-fA-F]{40}$"
          },
          "author": {
            "type": "string",
            "description": "Commit author identifier (name or username).",
            "minLength": 1
          },
          "message": {
            "type": "string",
            "description": "Full commit message.",
            "minLength": 1
          },
          "timestamp": {
            "type": "string",
            "description": "ISO-8601 datetime of the commit.",
            "format": "date-time"
          }
        }
      }
    },
    "approvals": {
      "type": "array",
      "description": "List of formal approvals collected for this change.",
      "items": {
        "type": "object",
        "required": ["approver", "role", "approved_at", "approval_method"],
        "additionalProperties": false,
        "properties": {
          "approver": {
            "type": "string",
            "description": "Username or display name of the approver.",
            "minLength": 1
          },
          "role": {
            "type": "string",
            "description": "Role or title of the approver, e.g. 'Software Safety Engineer'.",
            "minLength": 1
          },
          "approved_at": {
            "type": "string",
            "description": "ISO-8601 datetime of the approval.",
            "format": "date-time"
          },
          "approval_method": {
            "type": "string",
            "description": "Mechanism used to capture the approval.",
            "enum": ["github_review", "jira_transition"]
          },
          "artifact_ref": {
            "type": ["string", "null"],
            "description": "Reference to an external approval artifact (e.g. document ID, URL), or null."
          }
        }
      }
    },
    "traceability": {
      "type": "object",
      "description": "Traceability links to upstream and downstream artifacts.",
      "required": ["requirements", "design_docs", "test_cases"],
      "additionalProperties": false,
      "properties": {
        "requirements": {
          "type": "array",
          "description": "List of requirement IDs traced by this change.",
          "items": {
            "type": "string",
            "minLength": 1
          },
          "uniqueItems": true
        },
        "design_docs": {
          "type": "array",
          "description": "List of design document references (IDs, filenames, or URLs).",
          "items": {
            "type": "string",
            "minLength": 1
          },
          "uniqueItems": true
        },
        "test_cases": {
          "type": "array",
          "description": "List of test case IDs verified by this change.",
          "items": {
            "type": "string",
            "minLength": 1
          },
          "uniqueItems": true
        }
      }
    },
    "standard_compliance": {
      "type": "object",
      "description": "Mapping of this evidence record to applicable safety standard clauses and objectives.",
      "required": ["iec_62304_clauses", "iso_26262_clauses", "do_178c_objectives"],
      "additionalProperties": false,
      "properties": {
        "iec_62304_clauses": {
          "type": "array",
          "description": "IEC 62304 clauses satisfied by this evidence record.",
          "items": {
            "type": "string",
            "description": "Clause number, e.g. '5.5.1'.",
            "pattern": "^[0-9]+(\\.[0-9]+)*$"
          },
          "uniqueItems": true,
          "examples": [["5.1.6", "5.5", "5.6", "5.7", "5.8", "7"]]
        },
        "iso_26262_clauses": {
          "type": "array",
          "description": "ISO 26262-6 clauses satisfied by this evidence record.",
          "items": {
            "type": "string",
            "description": "Clause number, e.g. '6.4.6'.",
            "pattern": "^[0-9]+(\\.[0-9]+)*$"
          },
          "uniqueItems": true,
          "examples": [["6.4.6", "6.4.7", "6.4.8", "6.4.11"]]
        },
        "do_178c_objectives": {
          "type": "array",
          "description": "DO-178C table references and objectives satisfied by this evidence record.",
          "items": {
            "type": "string",
            "description": "DO-178C objective reference, e.g. 'A-5.1'.",
            "pattern": "^A-[0-9]+(\\.[0-9]+)*$"
          },
          "uniqueItems": true,
          "examples": [["A-4.1", "A-5.1", "A-7.1"]]
        }
      }
    },
    "integrity": {
      "type": "object",
      "description": "Cryptographic integrity and provenance information for this record.",
      "required": ["sha256_hash", "signed_by", "signature_timestamp"],
      "additionalProperties": false,
      "properties": {
        "sha256_hash": {
          "type": "string",
          "description": "SHA-256 hex digest of the canonical JSON serialization of this record (excluding the integrity field itself).",
          "pattern": "^[0-9a-fA-F]{64}$"
        },
        "signed_by": {
          "type": ["string", "null"],
          "description": "Identity of the signer (e.g. GitHub Actions bot identity, GPG key ID), or null if unsigned."
        },
        "signature_timestamp": {
          "type": ["string", "null"],
          "description": "ISO-8601 datetime when the signature was applied, or null if unsigned.",
          "format": "date-time"
        }
      }
    }
  }
}
